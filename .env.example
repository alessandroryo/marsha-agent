# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_USER=marsha
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=marsha_agent

# ============================================================
# OpenRouter API Key (daftar di https://openrouter.ai)
# WAJIB model BERBAYAR yang mendukung tool use (model :free tidak bisa).
# Tier: default deepseek/deepseek-v4-flash · delegation qwen/qwen3.5-9b
# (diatur di infra/hermes/config.yaml)
# ============================================================
OPENROUTER_API_KEY=sk-or-v1-...

# ============================================================
# FastAPI Gateway
# ============================================================
API_SECRET_KEY=change_me_random_secret

# ============================================================
# Telegram (Marsha bot + group topics)
# Token dari @BotFather; mengisi token = mengaktifkan platform Telegram.
# TELEGRAM_ALLOWED_USERS = user ID numerik yang boleh chat (batasi akses).
# TELEGRAM_GROUP_ID = chat_id supergroup (mis. -1001234567890), dipakai
# di config.yaml group_topics. Isi setelah membuat group + topics.
# ============================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_GROUP_ID=
